# ============================================================
# Environment Configuration Template
# ============================================================
# Copy this file to .env.local and fill in your credentials
# Run: cp .env.example .env.local
#
# Never commit .env.local or any real secrets to version control!
# ============================================================

# ============================================================
# Application
# ============================================================
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Patent Pilot
# Set to "true" to run in demo mode (no DB, Stripe, Resend, or auth backend needed)
# NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_APP_URL=http://localhost:3003
# For iOS Simulator, use your machine's LAN IP instead of localhost:
# EXPO_PUBLIC_APP_URL=http://192.168.x.x:3003
EXPO_PUBLIC_APP_URL=http://localhost:3003

# ============================================================
# Database — PostgreSQL via Drizzle ORM
# ============================================================
# Supabase: Settings → Database → Connection string (URI mode)
# Neon / Railway / local postgres also work.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp

# Supabase project URL + anon key — only needed if you use
# Supabase Storage, Realtime, or other non-Postgres features.
# The app's primary DB access goes through DATABASE_URL above.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# ============================================================
# Auth — Better-Auth
# https://better-auth.com
# ============================================================
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3003

# ============================================================
# Payments — Stripe (Web)
# https://dashboard.stripe.com/apikeys
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhooks → Developers → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# Products → find your price IDs
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ============================================================
# Payments — RevenueCat (Mobile IAP)
# https://app.revenuecat.com
# ============================================================
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_...
REVENUECAT_API_KEY=...
# Webhooks → Authorization header value
REVENUECAT_WEBHOOK_SECRET=...

# ============================================================
# Email — Resend
# https://resend.com/api-keys
# ============================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# Rate Limiting — Upstash Redis
# https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ============================================================
# Analytics — PostHog
# https://us.posthog.com/settings/project
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
EXPO_PUBLIC_POSTHOG_KEY=phc_...
EXPO_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ============================================================
# Error Tracking — Sentry
# https://sentry.io/settings/projects
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ============================================================
# Background Jobs — Inngest
# https://app.inngest.com/env/production/manage/keys
# ============================================================
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-prod-...

# ============================================================
# Tracing — OpenTelemetry (optional)
# ============================================================
# OTLP HTTP endpoint, e.g. Grafana Tempo / Honeycomb / Jaeger
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ============================================================
# Canary Rollouts — Vercel Edge Config (optional)
# ============================================================
# Auto-injected by Vercel when you link an Edge Config store.
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxx?token=xxx

# ============================================================
# Patent Pilot — EPO OPS API
# https://developers.epo.org → Register → OAuth2 credentials
# Free tier: 500k requests/month
# ============================================================
EPO_CLIENT_ID=...
EPO_CLIENT_SECRET=...
# Set true to skip EPO calls and return mock data (local dev)
# EPO_DRY_RUN=true

# ============================================================
# Patent Pilot — AI Provider
# One of: anthropic | openai | gemini (default: anthropic)
# ============================================================
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...
# Set true to skip AI calls and return mock data (local dev)
# AI_DRY_RUN=true

# ============================================================
# Patent Pilot — Email (Resend dry-run for local dev)
# ============================================================
# RESEND_DRY_RUN=true   ← set this for local dev, remove for prod
